<!DOCTYPE html>
<html>
<head>
<title>ShineMaster Packages</title>

<style>

body{
    background:#0f0f0f;
    font-family:Arial;
    color:white;
    margin:0;
}

.header{
    text-align:center;
    padding:30px;
}

.header h1{
    color:#ffd500;
}

.header h2{
    color:#9b5cff;
}

.container{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:25px;
    padding:20px;
}

.card{
    width:320px;
    background:#1a1a1a;
    border-radius:10px;
    padding:20px;
    box-shadow:0 8px 20px rgba(0,0,0,0.6);
    border-top:4px solid #ffd500;
}

.card h3{
    color:#ffd500;
}

.price{
    color:#9b5cff;
    font-size:18px;
    margin-bottom:10px;
}

ul{
    padding-left:18px;
}

li{
    margin-bottom:6px;
    font-size:14px;
}

.section{
    margin-top:40px;
}

.section-title{
    text-align:center;
    font-size:24px;
    color:#ffd500;
    margin-top:40px;
}

</style>

</head>

